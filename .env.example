# =========================================
# Flight Academy 環境変数テンプレート
# =========================================
# このファイルを .env.local にコピーして値を設定してください
# cp .env.example .env.local

# === Supabase (クライアント) ===
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# === Supabase (サーバー/スクリプト用、learning_contents登録等) ===
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Sentry (エラー監視) ===
# ローカル・任意: Vite 用（ビルド時にクライアントへ埋め込まれる）
VITE_SENTRY_DSN=
# Vercel Marketplace / Sentry 連携では NEXT_PUBLIC_SENTRY_DSN が自動設定される。
# vite.config は VITE_SENTRY_DSN が無いとき NEXT_PUBLIC_SENTRY_DSN を読む。
# 本番のソースマップアップロード用（Vercel 連携時も自動）:
# SENTRY_ORG=  SENTRY_PROJECT=  SENTRY_AUTH_TOKEN=

# === Google Analytics 4 (アクセス解析・任意) ===
# GA 管理画面の「Google タグ」の測定 ID（G- で始まるもの）と同じ値を使う。
# Vercel: Project → Settings → Environment Variables → Production に VITE_GA_MEASUREMENT_ID を追加し、
# 保存後に必ず再デプロイ（Vite はビルド時に HTML/バンドルへ埋め込むため）。
# ビルドログに「[vite] GA4: injecting gtag.js」が出ていれば index.html にタグが入る。出ない場合は変数がビルドに届いていない（環境の対象・ブランチ・未プッシュのコード等を確認）。
# 代替名: NEXT_PUBLIC_GA_MEASUREMENT_ID（同じ測定 ID をビルド時に読む場合）
# 本番ビルド時: index.html の <head> 直後に gtag.js が挿入され、SPA の各ルートで GoogleAnalyticsTracker が page_view を送る。
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# === Weather API (WeatherAPI.com) ===
# サーバー: Vercel 環境変数またはローカル .env（npm run dev の /api/weather プラグインが読む）
# WEATHER_API_KEY=your-weather-api-key
# クライアント（任意・現状は主にサーバープロキシ経由）
# VITE_WEATHER_API_KEY=your-weather-api-key

# === Supabase MCP (ツール用、ブラウザには露出しない) ===
# SUPABASE_ACCESS_TOKEN=your-access-token
# SUPABASE_PROJECT_ID=your-project-id

# === Google API (ツール用) ===
# GOOGLE_GEMINI_API_KEY=your-gemini-api-key
# GOOGLE_CLOUD_VISION_API_KEY=your-vision-api-key

# === Email (未使用、将来用) ===
# GMAIL_SMTP_USER=
# GMAIL_SMTP_PASSWORD=
# BREVO_API_KEY=

# === Sentry CI/CD (GitHub Actions シークレット) ===
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-project
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# === API（開発） ===
# Vite プロキシ: npm run dev + dev:weather 時の転送先（既定 3001）。必要なら:
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001
#
# vercel dev: package.json の dev:full が VITE_VERCEL_DEV_API_ORIGIN を付与。
# 加えて Vite 設定が VERCEL=1 / VERCEL_ENV=development のとき 3000 をクライアントに埋め込む（子プロセスで env が落ちる対策）。
# 別ポートで vercel dev する場合:
# VITE_VERCEL_DEV_API_ORIGIN=http://localhost:PORT
#
# === SWIM デジタルノータム（サーバのみ・Vite dev プラグイン / Vercel / dev-weather） ===
# .env.local に置くと npm run dev でも /api/swim-notam-search が動く（ブラウザに露出しないこと）
# SWIM_LOGIN_ID=your-portal-email@example.com
# SWIM_LOGIN_PASSWORD=your-password
# 検索 API の userId がログイン ID と異なる場合のみ:
# SWIM_SEARCH_USER_ID=

# === dev-weather-server（3001）と .env の併用 ===
# scripts/dev-weather-server は .env.local を読んだ後、.env.server.local で上書きする。
# SWIM を .env.local のみに書く場合でも読み込まれる。

# === OpenSky（サーバのみ・任意） ===
# 匿名で states API は利用可能。レート緩和したい場合のみ Vercel / .env に設定:
# OPENSKY_USERNAME=
# OPENSKY_PASSWORD=

# === ブランド PNG 透過（任意） ===
# python scripts/transparent_public_png.py F2favicon.png airplane.png

# === RainViewer（クライアント・任意） ===
# マニフェスト JSON が CORS で取れない場合 true にし、同一オリジンの /api/rainviewer-maps を使う
# VITE_RAINVIEWER_USE_MANIFEST_PROXY=true
# カスタム URL（上記と併用可）:
# VITE_RAINVIEWER_MANIFEST_URL=https://example.com/rainviewer-proxy.json
