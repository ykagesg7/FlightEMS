# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# local env files
.env*.local
.env.production

# Serena: per-machine overrides (committed baseline is .serena/project.yml)
.serena/project.local.yml

# Security: MCP configuration with sensitive data
.cursor/mcp.json
.cursor/mcp.json.backup*
backup_mcp_*.json

# Ignore temporary and backup files
temp/
*.txt
*.ps1
# Exception: Git encoding setup scripts
!scripts/setup-git-encoding.ps1
!scripts/git-commit-utf8.ps1
*-original.tsx
*.backup*
.env.local.backup*

# Gemini CLI (not in use)
.gemini/
.env.gemini.local

# Python virtual environment (CRITICAL FOR CURSOR PERFORMANCE)
.venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Do not ignore project TypeScript lib/ (api/* imports ../lib/*.ts) or api/lib/.
# Python build outputs live under build/ (ignored above).
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# Large data directories that slow down Cursor
cpl_exam_data/raw_pdfs/
cpl_exam_data/converted_md/
scripts/bulk_*.sql
scripts/batch_*.sql
scripts/unified_*.sql

# Temporary processing files
phase*.md
*_completion_report_*.md
batch_processing_*.json
batch_processing_*.md
.vercel

# Archive: optional staging (only .gitkeep is tracked; add exceptions if needed)
archive/*
!archive/.gitkeep

# Test coverage and cache
coverage/
.vitest/

# Large binary files
**/*.pdf
**/*.zip

# Scripts dependencies
scripts/docs-auto-update/node_modules/

# Supabase CLI temp
supabase/.temp/

# Vite temp
vite.config.ts.timestamp-*.mjs

# Playwright
playwright-report/
test-results/
blob-report/
playwright/.cache/

# Local scratch / API debug dumps (do not commit)
_os_body*.json
