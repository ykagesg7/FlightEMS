{
  "version": 2,
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "functions": {
    "api/cron/cohort-weekly.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/account/mfa-recovery-codes/(generate|consume|status|clear)",
      "dest": "/api/mfa-recovery-codes?action=$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(?!assets/)(.*)",
      "dest": "/index.html"
    }
  ],
  "devCommand": "vite --port 5173 --strictPort",
  "buildCommand": "npm run vercel-build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/cron/cohort-weekly",
      "schedule": "0 0 * * 0"
    }
  ]
}
